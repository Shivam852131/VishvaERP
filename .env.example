# Environment Variables
NODE_ENV=development
PORT=5000

# MongoDB
MONGO_URI=mongodb://localhost:27017/vishvaerp
MONGO_APP_NAME=VishvaERP
MONGO_MAX_POOL_SIZE=20
MONGO_MIN_POOL_SIZE=0
MONGO_CONNECT_RETRIES=5
MONGO_RETRY_DELAY_MS=1000
MONGO_SERVER_SELECTION_TIMEOUT_MS=10000
MONGO_SOCKET_TIMEOUT_MS=45000
MONGO_HEARTBEAT_MS=10000
MONGO_RETRY_WRITES=true
MONGO_AUTO_INDEX=true

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_2024
JWT_EXPIRE=7d

# OpenAI (optional - AI features work with mock if not set)
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email (optional - needed for password reset and notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM="VishvaERP <noreply@vishvaerp.com>"

# Razorpay Payment Gateway
# Use live credentials only on the backend. Never put RAZORPAY_KEY_SECRET in frontend code.
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Frontend URL (comma-separated for CORS + used in password reset links)
FRONTEND_URL=https://vishvaerp.vercel.app/

# Capacitor (mobile apps load this HTTPS URL in production)
# CAPACITOR_SERVER_URL=https://your-vishvaerp-domain.com

# Firebase Push Notifications (optional)
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Web Push VAPID keys (optional, for PWA notifications)
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=

# Android release signing (optional, for Play Store builds)
# ANDROID_KEYSTORE_PATH=
# ANDROID_KEYSTORE_PASSWORD=
# ANDROID_KEY_ALIAS=
# ANDROID_KEY_ALIAS_PASSWORD=

# Super Admin Seed
SUPER_ADMIN_EMAIL=superadmin@vishvaerp.com
SUPER_ADMIN_PASSWORD=SuperAdmin@123
