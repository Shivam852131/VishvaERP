{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/uploads/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/",
      "dest": "/frontend/index.html"
    },
    {
      "src": "/index.html",
      "dest": "/frontend/index.html"
    },
    {
      "src": "/manifest\\.webmanifest",
      "dest": "/frontend/manifest.webmanifest"
    },
    {
      "src": "/service-worker\\.js",
      "dest": "/frontend/service-worker.js"
    },
    {
      "src": "/offline\\.html",
      "dest": "/frontend/offline.html"
    },
    {
      "src": "/css/(.*)",
      "dest": "/frontend/css/$1"
    },
    {
      "src": "/js/(.*)",
      "dest": "/frontend/js/$1"
    },
    {
      "src": "/icons/(.*)",
      "dest": "/frontend/icons/$1"
    },
    {
      "src": "/live/(.*)",
      "dest": "/frontend/live/$1"
    },
    {
      "src": "/pages/(.*)",
      "dest": "/frontend/pages/$1"
    },
    {
      "src": "/docs/(.*)",
      "dest": "/frontend/docs/$1"
    },
    {
      "src": "/(.*\\.html)",
      "dest": "/frontend/$1"
    }
  ]
}
