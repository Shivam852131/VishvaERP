{
  "name": "vishva-erp",
  "version": "2.1.0",
  "description": "AI-Powered Multi-College ERP SaaS Platform",
  "main": "backend/server.js",
  "scripts": {
    "start": "node backend/server.js",
    "dev": "nodemon backend/server.js",
    "seed": "node backend/seeder.js",
    "install:all": "npm install",
    "frontend:build": "npm --prefix frontend-react run build",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:install": "playwright install chromium",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f backend",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop vishva-erp",
    "pm2:restart": "pm2 restart vishva-erp",
    "pm2:logs": "pm2 logs vishva-erp",
    "pm2:monit": "pm2 monit",
    "pm2:save": "pm2 save",
    "pm2:startup": "pm2 startup",
    "setup": "npm install && npm run pm2:start && npm run pm2:save",
    "vercel:build": "echo 'Vercel build step'",
    "vercel:start": "node backend/server.js",
    "render:build": "npm install",
    "render:start": "node backend/server.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.3.1",
    "express-validator": "^7.1.0",
    "firebase-admin": "^14.1.0",
    "google-auth-library": "^10.9.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.3.4",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.13",
    "openai": "^4.47.1",
    "pdfkit": "^0.15.0",
    "razorpay": "^2.9.6",
    "serverless-http": "^3.2.0",
    "sharp": "^0.35.3",
    "socket.io": "^4.8.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "nodemon": "^3.1.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
