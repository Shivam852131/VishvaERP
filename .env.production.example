# ============================================
# VishvaERP Production Environment Variables
# ============================================

# Server
NODE_ENV=production
PORT=5000

# MongoDB
MONGO_URI=mongodb://admin:CHANGE_ME_STRONG_PASSWORD@mongodb:27017/vishvaerp?authSource=admin
MONGO_USERNAME=admin
MONGO_PASSWORD=CHANGE_ME_STRONG_PASSWORD
MONGO_MAX_POOL_SIZE=50
MONGO_MIN_POOL_SIZE=5

# JWT
JWT_SECRET=CHANGE_ME_TO_RANDOM_64_CHAR_STRING
JWT_EXPIRE=7d

# Frontend
FRONTEND_URL=https://yourdomain.com

# AI (optional)
OPENAI_API_KEY=sk-your-openai-key-here

# Super Admin
SUPER_ADMIN_EMAIL=admin@yourdomain.com
SUPER_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Email (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@yourdomain.com

# Firebase Push Notifications (optional)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----"
FIREBASE_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com

# Logging
LOG_LEVEL=info
