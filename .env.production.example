# ============================================
# VishvaERP Production Environment Variables
# Copy this to .env and fill in your values
# ============================================

# Server
NODE_ENV=production
PORT=5000

# MongoDB (Atlas or self-hosted)
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/vishvaerp?retryWrites=true&w=majority
MONGO_MAX_POOL_SIZE=50
MONGO_MIN_POOL_SIZE=5
MONGO_SERVER_SELECTION_TIMEOUT_MS=10000
MONGO_SOCKET_TIMEOUT_MS=45000
MONGO_HEARTBEAT_MS=10000
MONGO_RETRY_WRITES=true
MONGO_AUTO_INDEX=false

# JWT (generate a 64-char random string: openssl rand -hex 32)
JWT_SECRET=CHANGE_ME_TO_RANDOM_64_CHAR_STRING
JWT_EXPIRE=7d

# Frontend URL (used for CORS and password reset links)
FRONTEND_URL=https://vishvaerp.vercel.app/

# Super Admin (auto-seeded on first run)
SUPER_ADMIN_EMAIL=admin@yourdomain.com
SUPER_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# OpenAI (optional - AI features work with mock if not set)
OPENAI_API_KEY=sk-your-openai-key-here

# Email (SMTP for password reset and notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="VishvaERP <noreply@yourdomain.com>"

# Firebase Push Notifications (optional)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----"
FIREBASE_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com

# Web Push VAPID keys (optional, for PWA notifications)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Razorpay Payment Gateway
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Logging
LOG_LEVEL=info

# PM2 Instance ID (set by PM2 automatically)
PM2_INSTANCE_ID=0
